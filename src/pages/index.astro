---
import '@fontsource/monofett';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <title>canys</title>
  </head>
  <body>
    <main>
      <h1
        ><span style="animation-delay: 0ms">c</span><span
          style="animation-delay: 90ms">a</span
        ><span style="animation-delay: 180ms">n</span><span
          style="animation-delay: 270ms">y</span
        ><span style="animation-delay: 360ms">s</span></h1
      >
    </main>
  </body>
</html>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    height: 100%;
    background: #000;
  }

  main {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    min-height: 100dvh;
  }

  h1 {
    margin: 0;
    font-family: 'Monofett', monospace;
    font-weight: 400;
    text-transform: lowercase;
    color: #fff;
    font-size: clamp(4rem, 22vw, 16rem);
    line-height: 1;
    letter-spacing: 0.04em;
    user-select: none;
  }

  h1 span {
    display: inline-block;
    opacity: 0;
    animation: letter-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes letter-in {
    0% {
      opacity: 0;
      transform: scale(3);
      filter: blur(10px);
    }
    100% {
      opacity: 1;
      transform: scale(1);
      filter: blur(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    h1 span {
      animation: none;
      opacity: 1;
    }
  }
</style>
